<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Flosum__OveridePullRequestValidation</fullName>
    <active>true</active>
    <errorConditionFormula>IF( ISNEW() ,  IF(AND(NOT($Permission.Flosum__Override_Pull_Request_Permission_for_the_Branch), Flosum__Enforce_pull_request__c = false),true,false),IF(AND(NOT($Permission.Flosum__Override_Pull_Request_Permission_for_the_Branch),  ISCHANGED( Flosum__Enforce_pull_request__c ) ),true,false) )</errorConditionFormula>
    <errorMessage>You can&apos;t override peer review setting.</errorMessage>
</ValidationRule>
