<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Flosum__Must_be_Same_Owner</fullName>
    <active>false</active>
    <errorConditionFormula>AND(Flosum__Org__r.Owner:User.Id != $User.Id, NOT($Setup.Flosum__Domain_Settings__c.Flosum__Is_Share_Organizations__c))</errorConditionFormula>
    <errorMessage>Only owner of organisation can share the record.</errorMessage>
</ValidationRule>
